---
import HeaderLink from "./HeaderLink.astro";
import ThemeToggle from "./ThemeToggle.astro";

const { title = "Dipankar Shaw" } = Astro.props;
---

<header class="sticky top-0 w-full z-50 bg-background/40 backdrop-blur-md border-b border-outline-variant/20 shadow-sm h-20 transition-all duration-500">
  <div class="max-w-container-max mx-auto h-full flex justify-between items-center px-margin-mobile md:px-margin-desktop">
    <a href="/" class="text-headline-lg font-black text-primary tracking-tighter">{title}</a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center gap-stack-md">
      <HeaderLink href="/#home">Home</HeaderLink>
      <HeaderLink href="#about">About</HeaderLink>
      <HeaderLink href="#experience">Experience</HeaderLink>
      <HeaderLink href="#skills">Skills</HeaderLink>
      <HeaderLink href="#certificates">Certificates</HeaderLink>
      <HeaderLink href="#projects">Projects</HeaderLink>
      <HeaderLink href="/blog">Blog</HeaderLink>
      <HeaderLink href="#contact">Contact</HeaderLink>
    </nav>

    <div class="flex items-center gap-4">
      <ThemeToggle />
      <a href="#contact" class="hidden sm:inline-block bg-primary text-on-primary px-6 py-2 rounded-full font-label-md text-label-md active:scale-95 transition-transform hover:opacity-90">Hire Me</a>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="md:hidden flex items-center justify-center p-2 text-on-surface-variant hover:text-primary transition-colors" aria-label="Toggle navigation menu">
        <span class="material-symbols-outlined">menu</span>
      </button>
    </div>
  </div>

  <!-- Mobile Dropdown Navigation -->
  <div id="mobile-menu" class="hidden md:hidden absolute top-20 left-0 w-full bg-background border-b border-outline-variant/20 shadow-lg px-margin-mobile py-4 flex flex-col gap-4">
    <a class="text-primary font-bold text-label-md font-label-md" href="#home">Home</a>
    <a class="text-on-surface-variant text-label-md font-label-md hover:text-primary" href="#about">About</a>
    <a class="text-on-surface-variant text-label-md font-label-md hover:text-primary" href="#experience">Experience</a>
    <a class="text-on-surface-variant text-label-md font-label-md hover:text-primary" href="#skills">Skills</a>
    <a class="text-on-surface-variant text-label-md font-label-md hover:text-primary" href="#certificates">Certificates</a>
    <a class="text-on-surface-variant text-label-md font-label-md hover:text-primary" href="#projects">Projects</a>
    <a class="text-on-surface-variant text-label-md font-label-md hover:text-primary" href="/blog">Blog</a>
    <a class="text-on-surface-variant text-label-md font-label-md hover:text-primary" href="#contact">Contact</a>
  </div>
</header>
<style>
</style>


<script>
// Active Nav Tracking
function setActiveClass(){
  let current = "";
  const sections = document.querySelectorAll("section");
  const navRes = document.querySelectorAll("nav a");

  sections.forEach((section) => {
      const sectionTop = section.offsetTop;
      if (pageYOffset >= sectionTop - 150) {
          current = section.getAttribute("id") || '';
      }
  });

  navRes.forEach((a) => {
    if (current && a.getAttribute("href")?.includes(current)) {
        a.classList.replace('notActive', 'active')
    }else{
      a.classList.replace('active', 'notActive');
    }
  });

}
window.addEventListener('scroll', () => {
  setActiveClass();
});
window.addEventListener('load', () => {
  setActiveClass();
})

// Mobile menu toggle
const mobileMenuBtn = document.getElementById('mobile-menu-btn');
const mobileMenu = document.getElementById('mobile-menu');
if (mobileMenuBtn && mobileMenu) {
  mobileMenuBtn.addEventListener('click', () => {
    mobileMenu.classList.toggle('hidden');
    const icon = mobileMenuBtn.querySelector('.material-symbols-outlined');
    if (icon) {
      icon.textContent = mobileMenu.classList.contains('hidden') ? 'menu' : 'close';
    }
  });

  // Close menu when clicking links
  mobileMenu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      const icon = mobileMenuBtn.querySelector('.material-symbols-outlined');
      if (icon) icon.textContent = 'menu';
    });
  });
}
</script>
