---
import Layout from "@/layouts/Layout.astro";
import ThemeToggle from "@/components/ThemeToggle.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
---

<Layout title="Dipankar Shaw • Full-Stack Developer" description="Full-Stack Developer based in Kolkata, India. Expert in JavaScript, TypeScript, Vue.js, Astro, Node.js, Express.js, and serverless ecosystems.">
  <!-- Top Navigation Bar -->
  <Header />
  <!-- Kinetic Background -->
  <div class="fixed inset-0 w-full h-full -z-10" style="display:block;">
    <canvas id="shader-canvas-ANIMATION_2" style="display:block;width:100%;height:100%"></canvas>
  </div>

  <main class="relative z-10 pt-20">
    <!-- Hero Section -->
    <section class="min-h-[90vh] flex flex-col items-center justify-center text-center px-margin-mobile" id="home">
      <div class="max-w-4xl w-full">
        <!-- Interactive wireframe structure -->
        <div class="w-full h-75 sm:h-100 mb-8" style="display:block;">
          <div id="threejs-container-ANIMATION_3" style="width:100%;height:100%"></div>
        </div>

        <h1 class="font-display-xl text-display-xl text-on-surface mb-stack-sm leading-none animate-in fade-in slide-in-from-bottom duration-1000">
          Hi, I am <span class="bg-linear-to-r from-primary to-indigo-500 bg-clip-text text-transparent">Dipankar Shaw</span>
        </h1>
        <strong class="text-headline-lg font-headline-lg text-primary block mb-4">Full-Stack Developer</strong>
        <p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl mx-auto mb-stack-lg opacity-85">
          From <b>Kolkata, West Bengal</b>. I architect and deploy production-ready applications, build robust REST APIs, and manage serverless ecosystems.
        </p>
        <div class="flex gap-stack-md justify-center">
          <a class="bg-primary text-on-primary px-8 py-4 rounded-lg font-bold text-body-md hover:translate-y-1 transition-all shadow-lg shadow-primary/20 hover:scale-105 hover:brightness-110" href="#projects">View Projects</a>
          <a class="bg-transparent border border-outline-variant text-on-surface px-8 py-4 rounded-lg font-bold text-body-md hover:bg-surface-container transition-all hover:scale-105 hover:brightness-110" href="#contact">Get in Touch</a>
        </div>
      </div>
    </section>

    <!-- About Section -->
    <section class="py-section-gap px-margin-mobile max-w-container-max mx-auto" id="about">
      <div class="grid md:grid-cols-2 gap-stack-lg items-center">
        <div class="reveal">
          <h2 class="font-display-lg text-display-lg text-primary mb-stack-md text-left">About Me</h2>
          <p class="font-body-lg text-body-lg text-on-surface-variant mb-stack-md leading-relaxed">
            I am a <b>Full-Stack Developer</b> with proven experience architecting and deploying production-ready applications. I specialize in developing robust REST APIs using Express.js alongside modern frameworks like Vue.js and Astro.
          </p>
          <p class="font-body-lg text-body-lg text-on-surface-variant mb-stack-lg leading-relaxed">
            Startup-tested with hands-on experience across diverse infrastructure, from Node.js to serverless ecosystems. I bring versatile engineering skills and a track record of production ownership to build reliable and scalable systems.
          </p>
          <div class="flex flex-wrap gap-stack-sm">
            <span class="px-4 py-1 bg-surface-container-high rounded-full text-primary font-label-sm text-label-sm border border-outline-variant/30">JavaScript (ES6+)</span>
            <span class="px-4 py-1 bg-surface-container-high rounded-full text-primary font-label-sm text-label-sm border border-outline-variant/30">TypeScript</span>
            <span class="px-4 py-1 bg-surface-container-high rounded-full text-primary font-label-sm text-label-sm border border-outline-variant/30">Vue.js</span>
            <span class="px-4 py-1 bg-surface-container-high rounded-full text-primary font-label-sm text-label-sm border border-outline-variant/30">React</span>
            <span class="px-4 py-1 bg-surface-container-high rounded-full text-primary font-label-sm text-label-sm border border-outline-variant/30">Astro</span>
            <span class="px-4 py-1 bg-surface-container-high rounded-full text-primary font-label-sm text-label-sm border border-outline-variant/30">Node.js</span>
            <span class="px-4 py-1 bg-surface-container-high rounded-full text-primary font-label-sm text-label-sm border border-outline-variant/30">Express.js</span>
            <span class="px-4 py-1 bg-surface-container-high rounded-full text-primary font-label-sm text-label-sm border border-outline-variant/30">Hono</span>
            <span class="px-4 py-1 bg-surface-container-high rounded-full text-primary font-label-sm text-label-sm border border-outline-variant/30">Cloudflare Workers</span>
            <span class="px-4 py-1 bg-surface-container-high rounded-full text-primary font-label-sm text-label-sm border border-outline-variant/30">SQL</span>
            <span class="px-4 py-1 bg-surface-container-high rounded-full text-primary font-label-sm text-label-sm border border-outline-variant/30">Python</span>
            <span class="px-4 py-1 bg-surface-container-high rounded-full text-primary font-label-sm text-label-sm border border-outline-variant/30">SEO Schema</span>
          </div>
        </div>
        <div class="reveal delay-200">
          <div class="relative group">
            <div class="absolute -inset-4 bg-primary/5 rounded-3xl blur-2xl group-hover:bg-primary/10 transition-colors"></div>
            <div class="relative rounded-2xl overflow-hidden shadow-xl border border-outline-variant/20 bg-gradient-to-tr from-primary/10 to-indigo-500/10 p-4">
              <img class="w-full max-w-sm mx-auto aspect-square object-cover rounded-xl shadow-lg border-2 border-primary/20 grayscale hover:grayscale-0 transition-all duration-700" src="/mypicnobg.png" alt="Dipankar Shaw">
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Experience & Education Section -->
    <section class="py-section-gap px-margin-mobile max-w-container-max mx-auto" id="experience">
      <div class="grid md:grid-cols-2 gap-stack-lg max-w-5xl mx-auto">
        <!-- Experience -->
        <div class="reveal">
          <h2 class="font-display-lg text-display-lg text-primary mb-stack-md text-left">Experience</h2>
          <div class="border-l-2 border-primary/20 pl-6 ml-2 space-y-8">
            <div class="relative">
              <div class="absolute -left-[31px] top-1.5 w-4 h-4 bg-primary rounded-full border-4 border-background"></div>
              <div class="mb-1">
                <span class="text-label-sm font-label-sm text-primary block">Sept 2025 – June 2026</span>
                <h3 class="text-headline-lg font-headline-lg text-on-surface">Full-Stack Developer Intern</h3>
                <span class="text-body-md font-bold text-on-surface-variant">Wiseboxs Technologies</span>
              </div>
              <ul class="list-disc list-outside ml-4 mt-2 space-y-1.5 text-on-surface-variant text-body-md">
                <li>Architected and deployed core features, managing end-to-end frontend and backend development.</li>
                <li>Developed dynamic, responsive UIs using modern frameworks, ensuring seamless backend integration.</li>
                <li>Engineered robust REST APIs using Express.js and Node.js, optimizing database queries.</li>
                <li>Managed complex codebases independently in a fast-paced environment, pushing stable code to production.</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Education -->
        <div class="reveal delay-200">
          <h2 class="font-display-lg text-display-lg text-primary mb-stack-md text-left">Education</h2>
          <div class="border-l-2 border-primary/20 pl-6 ml-2 space-y-8">
            <div class="relative">
              <div class="absolute -left-[31px] top-1.5 w-4 h-4 bg-primary rounded-full border-4 border-background"></div>
              <div class="mb-1">
                <span class="text-label-sm font-label-sm text-primary block">Graduation: Expected 2026</span>
                <h3 class="text-headline-lg font-headline-lg text-on-surface">Master of Computer Application (MCA)</h3>
                <span class="text-body-md font-bold text-on-surface-variant">RERF Group of Institutes (MAKAUT)</span>
              </div>
              <p class="text-on-surface-variant text-body-md mt-2 leading-relaxed">
                Academic foundation focusing on software engineering principles, relational databases, data structures, and advanced web technologies.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Technical Stack Section -->
    <section class="py-section-gap px-margin-mobile max-w-container-max mx-auto overflow-hidden" id="skills">
      <div class="text-center mb-stack-lg reveal">
        <h2 class="font-display-lg text-display-lg text-on-surface">The Technical Stack</h2>
        <p class="text-on-surface-variant">Continuous learning and systematic precision in every tool I use.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-stack-lg max-w-5xl mx-auto">
        <!-- Core Competencies -->
        <div class="space-y-stack-md reveal delay-100">
          <h3 class="text-headline-lg font-headline-lg mb-4 text-on-surface">Core Competencies</h3>
          <div class="space-y-4">
            <div>
              <div class="flex justify-between mb-1">
                <span class="font-label-md text-label-md text-on-surface">Frontend & UI Frameworks</span>
                <span class="font-label-md text-label-md text-primary">92%</span>
              </div>
              <div class="h-1.5 w-full bg-surface-container rounded-full overflow-hidden">
                <div class="h-full bg-primary transition-all duration-1000 w-[92%]"></div>
              </div>
              <p class="text-xs text-on-surface-variant mt-1">Vue.js, React, Astro, React Native, Tailwind CSS, Responsive Design</p>
            </div>
            <div>
              <div class="flex justify-between mb-1">
                <span class="font-label-md text-label-md text-on-surface">Backend & APIs</span>
                <span class="font-label-md text-label-md text-primary">95%</span>
              </div>
              <div class="h-1.5 w-full bg-surface-container rounded-full overflow-hidden">
                <div class="h-full bg-primary transition-all duration-1000 w-[95%]"></div>
              </div>
              <p class="text-xs text-on-surface-variant mt-1">Node.js, Express.js, Hono, GraphQL, FastAPI, Serverless Functions</p>
            </div>
            <div>
              <div class="flex justify-between mb-1">
                <span class="font-label-md text-label-md text-on-surface">Cloud & Database Infrastructure</span>
                <span class="font-label-md text-label-md text-primary">88%</span>
              </div>
              <div class="h-1.5 w-full bg-surface-container rounded-full overflow-hidden">
                <div class="h-full bg-primary transition-all duration-1000 w-[88%]"></div>
              </div>
              <p class="text-xs text-on-surface-variant mt-1">Cloudflare (Workers, Pages, D1, R2), PostgreSQL, SQLite, git pipelines, Linux</p>
            </div>
          </div>

          <div class="flex gap-4 mt-6">
            <a href="/skills/python" class="text-primary font-bold hover:underline inline-flex items-center gap-1">
              Explore Python Projects <span class="material-symbols-outlined text-sm">arrow_forward</span>
            </a>
            <a href="/skills/webdev" class="text-primary font-bold hover:underline inline-flex items-center gap-1">
              View Web Projects <span class="material-symbols-outlined text-sm">arrow_forward</span>
            </a>
          </div>
        </div>

        <!-- Tooling & Ecosystem -->
        <div class="flex flex-wrap content-start gap-4 reveal delay-200">
          <h3 class="text-headline-lg font-headline-lg mb-4 text-on-surface w-full">Tooling &amp; Ecosystem</h3>
          <div class="p-4 bg-surface rounded-xl shadow-sm border border-outline-variant/30 flex items-center gap-3 hover:border-primary transition-colors cursor-default">
            <span class="material-symbols-outlined text-primary">code</span>
            <span class="font-label-md text-label-md text-on-surface">Vue.js / React / Astro</span>
          </div>
          <div class="p-4 bg-surface rounded-xl shadow-sm border border-outline-variant/30 flex items-center gap-3 hover:border-primary transition-colors cursor-default">
            <span class="material-symbols-outlined text-primary">terminal</span>
            <span class="font-label-md text-label-md text-on-surface">Node.js / Express.js / Hono</span>
          </div>
          <div class="p-4 bg-surface rounded-xl shadow-sm border border-outline-variant/30 flex items-center gap-3 hover:border-primary transition-colors cursor-default">
            <span class="material-symbols-outlined text-primary">cloud</span>
            <span class="font-label-md text-label-md text-on-surface">Cloudflare Pages / Workers</span>
          </div>
          <div class="p-4 bg-surface rounded-xl shadow-sm border border-outline-variant/30 flex items-center gap-3 hover:border-primary transition-colors cursor-default">
            <span class="material-symbols-outlined text-primary">database</span>
            <span class="font-label-md text-label-md text-on-surface">PostgreSQL / SQLite / R2</span>
          </div>
          <div class="p-4 bg-surface rounded-xl shadow-sm border border-outline-variant/30 flex items-center gap-3 hover:border-primary transition-colors cursor-default">
            <span class="material-symbols-outlined text-primary">analytics</span>
            <span class="font-label-md text-label-md text-on-surface">JSON-LD & SEO Schema</span>
          </div>
          <div class="p-4 bg-surface rounded-xl shadow-sm border border-outline-variant/30 flex items-center gap-3 hover:border-primary transition-colors cursor-default">
            <span class="material-symbols-outlined text-primary">settings_suggest</span>
            <span class="font-label-md text-label-md text-on-surface">Git / GitHub / Linux</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Certifications Section -->
    <section class="py-section-gap px-margin-mobile bg-surface-container-low/30" id="certificates">
      <div class="max-w-container-max mx-auto">
        <div class="text-center mb-stack-lg reveal">
          <h2 class="font-display-lg text-display-lg text-on-surface">Certifications</h2>
          <p class="text-on-surface-variant max-w-xl mx-auto">
            Gained industry-standard knowledge through springboards and training platforms.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-stack-md">
          <!-- Cert 1 -->
          <div class="reveal group flex flex-col bg-surface rounded-xl overflow-hidden border border-outline-variant/20 transition-all duration-300 hover-card active hover:scale-[1.02] hover:shadow-primary/10">
            <div class="overflow-hidden relative h-48 bg-surface-container">
              <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" src="/python-certificate.png" alt="Python Certificate" loading="lazy" />
            </div>
            <div class="p-stack-md flex-grow flex flex-col justify-between">
              <div>
                <span class="text-label-sm font-label-sm text-primary mb-2 block">INFOSYS SPRINGBOARD</span>
                <h3 class="text-headline-lg font-headline-lg text-on-surface mb-stack-sm">Python Programming</h3>
              </div>
              <p class="text-primary font-label-sm text-label-sm mt-4">Issued: 2024</p>
            </div>
          </div>
          <!-- Cert 2 -->
          <div class="reveal delay-100 group flex flex-col bg-surface rounded-xl overflow-hidden border border-outline-variant/20 transition-all duration-300 hover-card active hover:scale-[1.02] hover:shadow-primary/10">
            <div class="overflow-hidden relative h-48 bg-surface-container">
              <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" src="/javascript-certificate.png" alt="JavaScript Certificate" loading="lazy" />
            </div>
            <div class="p-stack-md flex-grow flex flex-col justify-between">
              <div>
                <span class="text-label-sm font-label-sm text-primary mb-2 block">ONLINE TRAINING</span>
                <h3 class="text-headline-lg font-headline-lg text-on-surface mb-stack-sm">JavaScript Development</h3>
              </div>
              <p class="text-primary font-label-sm text-label-sm mt-4">Issued: 2025</p>
            </div>
          </div>
          <!-- Cert 3 -->
          <div class="reveal delay-200 group flex flex-col bg-surface rounded-xl overflow-hidden border border-outline-variant/20 transition-all duration-300 hover-card active hover:scale-[1.02] hover:shadow-primary/10">
            <div class="overflow-hidden relative h-48 bg-surface-container">
              <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" src="/bash-scripting-certificate.png" alt="Bash Scripting Certificate" loading="lazy" />
            </div>
            <div class="p-stack-md flex-grow flex flex-col justify-between">
              <div>
                <span class="text-label-sm font-label-sm text-primary mb-2 block">INFOSYS SPRINGBOARD</span>
                <h3 class="text-headline-lg font-headline-lg text-on-surface mb-stack-sm">Bash Scripting</h3>
              </div>
              <p class="text-primary font-label-sm text-label-sm mt-4">Issued: 2025</p>
            </div>
          </div>
        </div>

        <div class="view-more-container mt-stack-lg text-center">
          <a href="/certificates" class="inline-flex items-center gap-2 bg-primary text-on-primary px-8 py-3 rounded-lg font-bold text-body-md hover:translate-y-[-2px] hover:shadow-lg transition-all active:scale-[0.98]">
            <span>View All Certificates</span>
            <span class="material-symbols-outlined text-sm">arrow_forward</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Projects Section -->
    <section class="py-section-gap px-margin-mobile" id="projects">
      <div class="max-w-container-max mx-auto">
        <div class="text-center mb-stack-lg reveal">
          <h2 class="font-display-lg text-display-lg text-on-surface mb-2">Featured Projects</h2>
          <p class="text-on-surface-variant max-w-lg mx-auto">A selection of my recent works where design meets robust engineering.</p>
        </div>

        <div class="grid md:grid-cols-3 gap-stack-md">
          <!-- Project 1: Craft-o-Card -->
          <div class="reveal group flex flex-col bg-surface rounded-xl overflow-hidden border border-outline-variant/20 transition-all duration-300 hover-card active hover:scale-[1.02] hover:shadow-primary/10">
            <div class="overflow-hidden relative h-48 bg-surface-container">
              <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" src="/project-placeholder.svg" alt="Craft-o-Card" loading="lazy" />
            </div>
            <div class="p-stack-md flex-grow flex flex-col justify-between">
              <div>
                <span class="text-label-sm font-label-sm text-primary mb-2 block">PORTFOLIO & E-COMMERCE</span>
                <h3 class="text-headline-lg font-headline-lg text-on-surface mb-stack-sm">Craft-o-Card</h3>
                <p class="text-on-surface-variant text-body-md mb-stack-md">
                  Commercial web app developed from requirements to public launch. Integrated structured data (JSON-LD) for SEO and automated pipelines for 100% uptime.
                </p>
              </div>
              <div>
                <div class="flex gap-2 mb-4 flex-wrap">
                  <span class="bg-surface-variant/50 text-on-surface-variant px-3 py-1 rounded text-label-sm font-label-sm">Vue.js</span>
                  <span class="bg-surface-variant/50 text-on-surface-variant px-3 py-1 rounded text-label-sm font-label-sm">Hono</span>
                  <span class="bg-surface-variant/50 text-on-surface-variant px-3 py-1 rounded text-label-sm font-label-sm">Cloudflare R2</span>
                </div>
                <div class="flex gap-4">
                  <a href="https://craftocard.in" target="_blank" class="text-primary font-bold hover:underline inline-flex items-center gap-1 text-sm">
                    Live Demo <span class="material-symbols-outlined text-sm">open_in_new</span>
                  </a>
                </div>
              </div>
            </div>
          </div>

          <!-- Project 2: Nexrepo -->
          <div class="reveal delay-100 group flex flex-col bg-surface rounded-xl overflow-hidden border border-outline-variant/20 transition-all duration-300 hover-card active hover:scale-[1.02] hover:shadow-primary/10">
            <div class="overflow-hidden relative h-48 bg-surface-container">
              <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" src="/project-placeholder.svg" alt="Nexrepo" loading="lazy" />
            </div>
            <div class="p-stack-md flex-grow flex flex-col justify-between">
              <div>
                <span class="text-label-sm font-label-sm text-primary mb-2 block">AUTOMATION & UTILITIES</span>
                <h3 class="text-headline-lg font-headline-lg text-on-surface mb-stack-sm">Nexrepo</h3>
                <p class="text-on-surface-variant text-body-md mb-stack-md">
                  Automated disaster recovery tool to backup GitHub repos to private cloud. Uses GitHub APIs for real-time webhooks, delta backups, and OAuth credentials pipeline.
                </p>
              </div>
              <div>
                <div class="flex gap-2 mb-4 flex-wrap">
                  <span class="bg-surface-variant/50 text-on-surface-variant px-3 py-1 rounded text-label-sm font-label-sm">Astro</span>
                  <span class="bg-surface-variant/50 text-on-surface-variant px-3 py-1 rounded text-label-sm font-label-sm">Vue.js</span>
                  <span class="bg-surface-variant/50 text-on-surface-variant px-3 py-1 rounded text-label-sm font-label-sm">Hono</span>
                  <span class="bg-surface-variant/50 text-on-surface-variant px-3 py-1 rounded text-label-sm font-label-sm">OAuth</span>
                </div>
                <div class="flex gap-4">
                  <a href="https://nexrepo.qzz.io" target="_blank" class="text-primary font-bold hover:underline inline-flex items-center gap-1 text-sm">
                    Live Demo <span class="material-symbols-outlined text-sm">open_in_new</span>
                  </a>
                </div>
              </div>
            </div>
          </div>

          <!-- Project 3: AI Mock Exam -->
          <div class="reveal delay-200 group flex flex-col bg-surface rounded-xl overflow-hidden border border-outline-variant/20 transition-all duration-300 hover-card active hover:scale-[1.02] hover:shadow-primary/10">
            <div class="overflow-hidden relative h-48 bg-surface-container">
              <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" src="/project-placeholder.svg" alt="AI Mock Exam" loading="lazy" />
            </div>
            <div class="p-stack-md flex-grow flex flex-col justify-between">
              <div>
                <span class="text-label-sm font-label-sm text-primary mb-2 block">EDTECH & AI PREPARATION</span>
                <h3 class="text-headline-lg font-headline-lg text-on-surface mb-stack-sm">AI Mock Exam</h3>
                <p class="text-on-surface-variant text-body-md mb-stack-md">
                  AI based mock test application for exam preparation, integrated with large language models to dynamically generate and rate exams.
                </p>
              </div>
              <div>
                <div class="flex gap-2 mb-4 flex-wrap">
                  <span class="bg-surface-variant/50 text-on-surface-variant px-3 py-1 rounded text-label-sm font-label-sm">FastAPI</span>
                  <span class="bg-surface-variant/50 text-on-surface-variant px-3 py-1 rounded text-label-sm font-label-sm">React</span>
                  <span class="bg-surface-variant/50 text-on-surface-variant px-3 py-1 rounded text-label-sm font-label-sm">Tailwind CSS</span>
                </div>
                <div class="flex gap-4">
                  <a href="https://makautmocktest.netlify.app" target="_blank" class="text-primary font-bold hover:underline inline-flex items-center gap-1 text-sm">
                    Live Demo <span class="material-symbols-outlined text-sm">open_in_new</span>
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="view-more-container mt-stack-lg text-center">
          <a href="/projects" class="inline-flex items-center gap-2 bg-transparent border border-outline-variant text-on-surface px-8 py-3 rounded-lg font-bold text-body-md hover:bg-surface-container transition-all hover:scale-105">
            <span>View All Projects</span>
            <span class="material-symbols-outlined text-sm">arrow_forward</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Contact Section -->
    <section class="py-section-gap px-margin-mobile relative" id="contact">
      <div class="max-w-2xl mx-auto glass-panel p-stack-lg rounded-3xl reveal relative overflow-hidden">
        <!-- Inner glow effect -->
        <div class="absolute -top-24 -right-24 w-48 h-48 bg-primary/10 rounded-full blur-3xl"></div>
        <h2 class="font-display-lg text-display-lg text-on-surface text-center mb-stack-sm">Let's Connect</h2>
        <p class="text-on-surface-variant text-center mb-stack-lg">
          I'm seeking full-time roles to bring my engineering experience and production ownership to your team.
        </p>

        <div class="grid md:grid-cols-2 gap-4 mb-stack-md p-4 bg-surface-container-low/50 rounded-2xl border border-outline-variant/20">
          <div class="flex items-center gap-3">
